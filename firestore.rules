// Regras de segurança do Firestore para o GymFlow
// APENAS usuários com email verificado podem acessar o Firestore
// Copie essas regras para o Console do Firebase > Firestore Database > Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // BLOQUEIO TOTAL para usuários não autenticados - APENAS usuários com email verificado
    match /users/{userId} {
      // Permitir acesso APENAS se:
      // 1. Usuário está autenticado
      // 2. UID corresponde ao documento
      // 3. Email está verificado
      allow read, write: if request.auth != null 
                      && request.auth.uid == userId 
                      && request.auth.token.email_verified == true;
      
      // Subcoleções de dados do usuário (mesmas regras)
      match /data/{collection} {
        allow read, write: if request.auth != null 
                        && request.auth.uid == userId 
                        && request.auth.token.email_verified == true;
      }
    }
    
    // Negar acesso a tudo o que não está explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}